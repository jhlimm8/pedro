# Required: API key for the OpenAI-compatible endpoint we'll talk to.
# - For real OpenAI:  your sk-... key
# - For LiteLLM:      your LiteLLM virtual key (also looks like sk-...)
OPENAI_API_KEY=sk-...

# Optional: route the OpenAI client through a different OpenAI-compatible
# base URL. Leave unset to hit api.openai.com directly.
# Example for a local LiteLLM proxy:
#   OPENAI_BASE_URL=http://localhost:4000
# (PEDRO_OPENAI_BASE_URL is also accepted and takes priority of the project-
# local name if you want to keep this distinct from system-wide OPENAI_BASE_URL.)
# OPENAI_BASE_URL=

# Optional overrides
PEDRO_MODEL=gpt-5
PEDRO_REASONING_EFFORT=low
PEDRO_SCOUT_MAX_SUBQUESTIONS=5
PEDRO_DEEP_MAX_SUBQUESTIONS=8
PEDRO_REQUEST_TIMEOUT_S=180

# Where SSE event traces get appended (one JSONL file per session).
# Leave blank to disable tracing.
PEDRO_TRACE_DIR=traces

# Set to 1 to enable real-API smoke tests
PEDRO_RUN_SMOKE=0
